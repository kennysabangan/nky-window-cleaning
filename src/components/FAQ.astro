---
interface Props {
  question: string;
  answer: string;
}

const { question, answer } = Astro.props;
---
<details class="border border-gray-200 rounded-lg group">
  <summary class="cursor-pointer px-6 py-4 font-semibold text-[#1e3a5f] flex items-center justify-between hover:bg-gray-50 transition-colors">
    {question}
    <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
    </svg>
  </summary>
  <div class="px-6 pb-4 text-gray-600 text-sm leading-relaxed">
    {answer}
  </div>
</details>
