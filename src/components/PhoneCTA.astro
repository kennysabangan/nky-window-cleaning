---
interface Props {
  phone?: string;
  label?: string;
}

const { phone = "(859) 555-0100", label = "Call Now for a Free Estimate" } = Astro.props;
const href = `tel:+18595550100`;
---
<table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin:15px 0;">
  <tr>
    <td align="center">
      <a href={href} class="callrail-number" style="display:inline-block; background:#1a6bb5; color:#fff; padding:14px 30px; font-size:22px; font-weight:bold; text-decoration:none; border:3px solid #0d4f8a;">
        📞 {label}: {phone}
      </a>
    </td>
  </tr>
</table>
