---
// QuoteForm.astro — Lead capture form
---

<section class="bg-white py-12">
  <div class="max-w-[500px] mx-auto px-4">
    <div class="bg-green-700 text-white text-center rounded-t-lg py-6 px-4">
      <p class="text-2xl md:text-3xl font-bold tracking-wide">FREE INSTANT QUOTE</p>
      <p class="text-green-100 text-sm mt-1">Enter your info below</p>
    </div>

    <form
      class="bg-gray-50 border border-t-0 border-gray-200 rounded-b-lg p-6 space-y-4"
      id="quote-form"
    >
      <input type="hidden" name="site_name" value="NKY Window Cleaning Pros" />
      <input type="hidden" name="page_path" value="" />

      <div>
        <label for="quote-first-name" class="block text-sm font-medium text-gray-700 mb-1">First Name *</label>
        <input type="text" id="quote-first-name" name="first_name" required
          class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-600 focus:border-transparent" />
      </div>

      <div>
        <label for="quote-last-name" class="block text-sm font-medium text-gray-700 mb-1">Last Name *</label>
        <input type="text" id="quote-last-name" name="last_name" required
          class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-600 focus:border-transparent" />
      </div>

      <div>
        <label for="quote-email" class="block text-sm font-medium text-gray-700 mb-1">Email *</label>
        <input type="email" id="quote-email" name="email" required
          class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-600 focus:border-transparent" />
      </div>

      <div>
        <label for="quote-phone" class="block text-sm font-medium text-gray-700 mb-1">Phone</label>
        <input type="tel" id="quote-phone" name="phone"
          class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-600 focus:border-transparent" />
      </div>

      <div>
        <label for="quote-comment" class="block text-sm font-medium text-gray-700 mb-1">Message</label>
        <textarea id="quote-comment" name="comment" rows="4"
          placeholder="TELL US ABOUT YOUR PROJECT"
          class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-600 focus:border-transparent resize-vertical"></textarea>
      </div>

      <button type="submit"
        class="w-full bg-green-700 hover:bg-green-800 text-white font-bold py-3 rounded text-base transition-colors">
        Get My Free Quote
      </button>
    </form>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('quote-form') as HTMLFormElement;
    if (!form) return;

    const pagePathInput = form.querySelector('input[name="page_path"]') as HTMLInputElement;
    if (pagePathInput) pagePathInput.value = window.location.pathname;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      const originalText = btn.textContent;
      btn.textContent = 'Sending...';
      btn.disabled = true;

      const formData = new FormData(form);
      const data = Object.fromEntries(formData.entries());

      try {
        const res = await fetch('/api/lead', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        if (res.ok) {
          form.innerHTML = '<div class="text-center py-8"><p class="text-green-700 text-xl font-bold">✓ Thank you!</p><p class="text-gray-600 mt-2">We received your request and will get back to you shortly.</p></div>';
        } else {
          throw new Error('Failed');
        }
      } catch (err) {
        btn.textContent = originalText;
        btn.disabled = false;
        alert('Something went wrong. Please try again or call us directly.');
      }
    });
  });
</script>
