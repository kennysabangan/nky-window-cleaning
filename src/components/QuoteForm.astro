---
// QuoteForm.astro — Simple free quote request form
---

<section class="bg-white py-12">
  <div class="max-w-[500px] mx-auto px-4">
    <!-- Green banner -->
    <div class="bg-green-700 text-white text-center rounded-t-lg py-6 px-4">
      <p class="text-2xl md:text-3xl font-bold tracking-wide">FREE INSTANT QUOTE</p>
      <p class="text-green-100 text-sm mt-1">Enter your info below</p>
    </div>

    <!-- Form -->
    <form
      class="bg-gray-50 border border-t-0 border-gray-200 rounded-b-lg p-6 space-y-4"
      onsubmit="return false"
    >
      <div>
        <label for="quote-name" class="block text-sm font-medium text-gray-700 mb-1">Name *</label>
        <input
          type="text"
          id="quote-name"
          name="name"
          required
          class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-600 focus:border-transparent"
        />
      </div>

      <div>
        <label for="quote-phone" class="block text-sm font-medium text-gray-700 mb-1">Phone *</label>
        <input
          type="tel"
          id="quote-phone"
          name="phone"
          required
          class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-600 focus:border-transparent"
        />
      </div>

      <div>
        <label for="quote-message" class="block text-sm font-medium text-gray-700 mb-1">Message</label>
        <textarea
          id="quote-message"
          name="message"
          rows="4"
          placeholder="Tell us about your windows — how many, inside/outside, any hard-to-reach areas?"
          class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-600 focus:border-transparent resize-vertical"
        ></textarea>
      </div>

      <button
        type="submit"
        class="w-full bg-green-700 hover:bg-green-800 text-white font-bold py-3 rounded text-base transition-colors"
      >
        Get My Free Quote
      </button>
    </form>
  </div>
</section>
