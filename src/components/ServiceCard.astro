---
interface Props {
  service: {
    title: string;
    description: string;
    photo?: string;
  };
}

const { service } = Astro.props;
---
<div class="service-card">
  <img
    src={service.photo || "/photos/window-cleaning-1.jpg"}
    alt={service.title}
    loading="lazy"
  />
  <div class="card-body">
    <h3>{service.title}</h3>
    <p>{service.description}</p>
  </div>
</div>
