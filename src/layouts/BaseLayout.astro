---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonicalURL?: string;
  schema?: object | object[];
}

const { title, description, canonicalURL, schema } = Astro.props;
const site = "https://nkywindowcleaningpros.com";
const fullCanonical = canonicalURL || `${site}${Astro.url.pathname}`;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={fullCanonical} />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={fullCanonical} />
  <meta property="og:site_name" content="NKY Window Cleaning Pros" />

  <!-- CallRail DNI -->
  <script type="text/javascript">
    // CallRail Dynamic Number Insertion - replace ACCOUNT_ID with actual ID
    var js = document.createElement('script');
    js.src = 'https://cdn.callrail.com/companies/ACCOUNT_ID/1234567890/swap.js';
    document.head.appendChild(js);
  </script>

  {schema && Array.isArray(schema) && schema.map((s) => (
    <script type="application/ld+json" set:html={JSON.stringify(s)} />
  ))}
  {schema && !Array.isArray(schema) && (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  )}
</head>
<body>

<!-- Header -->
<header class="bg-brand text-white border-b border-white/10 shadow-sm">
  <div class="container">
    <div class="flex flex-col items-center gap-2 py-3 sm:flex-row sm:justify-between sm:items-center">
      <a href="/" class="text-lg font-bold text-white no-underline hover:no-underline tracking-tight">
        NKY Window Cleaning Pros
      </a>
      <a href="tel:+18595550100" class="callrail-number inline-flex items-center gap-1.5 bg-white text-brand font-semibold text-sm px-4 py-2 rounded-md no-underline hover:bg-gray-100 transition-colors min-h-[48px] justify-center">
        📞 (859) 555-0100
      </a>
    </div>
  </div>
</header>

<!-- Nav -->
<nav class="bg-gray-50 border-b border-gray-200">
  <div class="container">
    <div class="flex flex-wrap justify-center gap-x-1 gap-y-1 py-2.5 text-sm">
      <a href="/" class="text-brand no-underline hover:no-underline px-2 py-1">Home</a>
      <span class="text-gray-300">|</span>
      <a href="/window-cleaning/" class="text-brand no-underline hover:no-underline px-2 py-1">Services</a>
      <span class="text-gray-300">|</span>
      <a href="/reviews/" class="text-brand no-underline hover:no-underline px-2 py-1">Reviews</a>
      <span class="text-gray-300">|</span>
      <a href="/about/" class="text-brand no-underline hover:no-underline px-2 py-1">About Us</a>
    </div>
  </div>
</nav>

<main>
  <slot />
</main>

<!-- Footer -->
<footer class="bg-gray-800 text-gray-300 mt-10">
  <div class="container py-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Column 1: Brand -->
      <div>
        <p class="text-white font-bold text-base mb-2">NKY Window Cleaning Pros</p>
        <p class="text-sm text-gray-400 leading-relaxed">
          Professional window cleaning services in Northern Kentucky. Locally owned and operated.
        </p>
      </div>
      <!-- Column 2: Contact -->
      <div>
        <p class="text-white font-semibold text-sm mb-2">Contact Us</p>
        <p class="text-sm text-gray-400 leading-relaxed">
          📞 <a href="tel:+18595550100" class="callrail-number text-white no-underline">(859) 555-0100</a><br/>
          Free estimates on all window cleaning services.
        </p>
      </div>
      <!-- Column 3: Service Areas -->
      <div>
        <p class="text-white font-semibold text-sm mb-2">Service Areas</p>
        <p class="text-sm text-gray-400 leading-relaxed">
          Florence · Covington · Fort Mitchell · Erlanger · Newport · Independence · Edgewood · Fort Thomas · Bellevue · Cold Spring · Taylor Mill · Villa Hills · Crescent Springs · Lakeside Park · Park Hills
        </p>
      </div>
    </div>
    <div class="border-t border-gray-600 mt-6 pt-4">
      <p class="text-xs text-gray-500 text-center">
        &copy; {new Date().getFullYear()} NKY Window Cleaning Pros. All rights reserved. | Window Cleaning Northern Kentucky | Residential &amp; Commercial Window Cleaning
      </p>
    </div>
  </div>
</footer>

</body>
</html>
