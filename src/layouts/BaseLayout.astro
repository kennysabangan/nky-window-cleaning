---
import '../styles/global.css';
import { siteConfig } from '../config';

interface Props {
  title: string;
  description: string;
  canonicalURL?: string;
  schema?: object | object[];
}

const { title, description, canonicalURL, schema } = Astro.props;
const { businessName, phone, phoneE164, siteUrl, region, cities, ga4MeasurementId, gtmContainerId, hasGA4, hasGTM } = siteConfig;
const fullCanonical = canonicalURL || `${siteUrl}${Astro.url.pathname}`;

// LocalBusiness schema on every page
const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": businessName,
  "description": `Professional ${siteConfig.serviceKeywordPlural} in ${siteConfig.city}.`,
  "url": siteUrl,
  "telephone": phoneE164,
  "priceRange": "$$",
  "openingHours": siteConfig.openingHours,
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": siteConfig.geoLat,
    "longitude": siteConfig.geoLng,
  },
  "image": `${siteUrl}/photos/hero.jpg`,
  "areaServed": cities.map((c) => ({
    "@type": "City",
    "name": c.name,
  })),
  "serviceType": [
    siteConfig.serviceKeyword.charAt(0).toUpperCase() + siteConfig.serviceKeyword.slice(1),
    `Residential ${siteConfig.serviceKeyword}`,
    `Commercial ${siteConfig.serviceKeyword}`,
  ],
};

// Merge LocalBusiness + any page-specific schemas
const allSchemas = schema
  ? Array.isArray(schema)
    ? [localBusinessSchema, ...schema]
    : [localBusinessSchema, schema]
  : [localBusinessSchema];
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="index, follow" />
  <meta name="theme-color" content="#1a6bb5" />
  <meta name="format-detection" content="telephone=no" />

  <!-- Favicon -->
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/favicon.png" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

  <!-- SEO -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={fullCanonical} />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={fullCanonical} />
  <meta property="og:site_name" content={businessName} />
  <meta property="og:locale" content="en_US" />
  <meta property="og:image" content={`${siteUrl}/photos/hero.jpg`} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={`${siteUrl}/photos/hero.jpg`} />

  <!-- Google Analytics 4 -->
  {hasGA4 && (
    <>
      <script async src={`https://www.googletagmanager.com/gtag/js?id=${ga4MeasurementId}`}></script>
      <script set:html={`
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', '${ga4MeasurementId}');
      `}></script>
    </>
  )}

  <!-- Google Tag Manager (head) -->
  {hasGTM && (
    <script set:html={`
      (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
      new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
      'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
      })(window,document,'script','dataLayer','${gtmContainerId}');
    `}></script>
  )}

  <!-- JSON-LD schemas -->
  {allSchemas.map((s) => (
    <script type="application/ld+json" set:html={JSON.stringify(s)} />
  ))}
</head>
<body>

<!-- Google Tag Manager (noscript) -->
{hasGTM && (
  <noscript set:html={`<iframe src="https://www.googletagmanager.com/ns.html?id=${gtmContainerId}"
    height="0" width="0" style="display:none;visibility:hidden"></iframe>`}></noscript>
)}

<main>
  <slot />
</main>

<!-- Footer -->
<footer class="bg-gray-800 text-gray-300 mt-10">
  <div class="container py-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Column 1: Brand -->
      <div>
        <p class="text-white font-bold text-base mb-2">{businessName}</p>
        <p class="text-sm text-gray-400 leading-relaxed">
          Professional {siteConfig.serviceKeywordPlural} in {siteConfig.city}. Locally owned and operated.
        </p>
      </div>
      <!-- Column 2: Contact -->
      <div>
        <p class="text-white font-semibold text-sm mb-2">Contact Us</p>
        <p class="text-sm text-gray-400 leading-relaxed">
          📞 <a href={`tel:${phoneE164}`} class="text-white no-underline">{phone}</a><br/>
          Free estimates on all {siteConfig.serviceKeywordPlural}.
        </p>
      </div>
      <!-- Column 3: Service Areas -->
      <div>
        <p class="text-white font-semibold text-sm mb-2">Service Areas</p>
        <p class="text-sm text-gray-400 leading-relaxed">
          {cities.map((c) => c.name.replace(/, KY$/, '')).join(' · ')}
        </p>
      </div>
    </div>
    <div class="border-t border-gray-600 mt-6 pt-4">
      <p class="text-xs text-gray-500 text-center">
        &copy; {new Date().getFullYear()} {businessName}. All rights reserved. | {siteConfig.serviceKeyword.charAt(0).toUpperCase() + siteConfig.serviceKeyword.slice(1)} {siteConfig.city} | Residential &amp; Commercial {siteConfig.serviceKeyword}
      </p>
    </div>
  </div>
</footer>

</body>
</html>
