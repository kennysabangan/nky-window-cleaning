---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonicalURL?: string;
  schema?: object | object[];
}

const { title, description, canonicalURL, schema } = Astro.props;
const site = "https://nkywindowcleaningpros.com";
const fullCanonical = canonicalURL || `${site}${Astro.url.pathname}`;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={fullCanonical} />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={fullCanonical} />
  <meta property="og:site_name" content="NKY Window Cleaning Pros" />

  <!-- CallRail DNI -->
  <script type="text/javascript">
    // CallRail Dynamic Number Insertion - replace ACCOUNT_ID with actual ID
    var js = document.createElement('script');
    js.src = 'https://cdn.callrail.com/companies/ACCOUNT_ID/1234567890/swap.js';
    document.head.appendChild(js);
  </script>

  {schema && Array.isArray(schema) && schema.map((s) => (
    <script type="application/ld+json" set:html={JSON.stringify(s)} />
  ))}
  {schema && !Array.isArray(schema) && (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  )}
</head>
<body style="margin:0; padding:0;">

<!-- Header — simple, not fancy -->
<table width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#1a6bb5; color:#fff; padding:10px 0;">
  <tr>
    <td align="center" style="padding:10px 15px;">
      <table width="780" cellpadding="0" cellspacing="0" border="0">
        <tr>
          <td style="font-size:20px; font-weight:bold; color:#fff;">
            <a href="/" style="color:#fff; text-decoration:none;">NKY Window Cleaning Pros</a>
          </td>
          <td align="right" style="font-size:14px;">
            <a href="tel:+18595550100" class="callrail-number" style="color:#fff; font-weight:bold; text-decoration:none; background:#fff; color:#1a6bb5; padding:6px 14px; border:2px solid #fff;">📞 (859) 555-0100</a>
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>

<!-- Simple nav bar -->
<table width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#f5f5f5; border-bottom:1px solid #ddd;">
  <tr>
    <td align="center" style="padding:6px 15px; font-size:14px;">
      <a href="/" style="color:#1a6bb5; text-decoration:none; margin:0 10px;">Home</a>
      |
      <a href="/window-cleaning/" style="color:#1a6bb5; text-decoration:none; margin:0 10px;">Window Cleaning Services</a>
      |
      <a href="/reviews/" style="color:#1a6bb5; text-decoration:none; margin:0 10px;">Reviews</a>
      |
      <a href="/about/" style="color:#1a6bb5; text-decoration:none; margin:0 10px;">About Us</a>
    </td>
  </tr>
</table>

<main>
  <slot />
</main>

<!-- Footer — simple -->
<table width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#333; color:#ccc; margin-top:30px;">
  <tr>
    <td align="center" style="padding:20px 15px;">
      <table width="780" cellpadding="0" cellspacing="0" border="0">
        <tr>
          <td style="color:#fff; font-size:16px; font-weight:bold; padding-bottom:8px;">
            NKY Window Cleaning Pros
          </td>
        </tr>
        <tr>
          <td style="color:#ccc; font-size:13px; line-height:1.8; padding-bottom:8px;">
            📞 Call Us: <a href="tel:+18595550100" class="callrail-number" style="color:#fff; text-decoration:none;">(859) 555-0100</a><br>
            Serving Florence, Covington, Fort Mitchell, Erlanger, Newport, Independence, Edgewood, Fort Thomas, Bellevue, Cold Spring, Taylor Mill, Villa Hills, Crescent Springs, Lakeside Park, Park Hills, and all of Northern Kentucky.
          </td>
        </tr>
        <tr>
          <td style="color:#999; font-size:12px; padding-top:10px; border-top:1px solid #555;">
            &copy; {new Date().getFullYear()} NKY Window Cleaning Pros. All rights reserved. | Window Cleaning Northern Kentucky | Residential &amp; Commercial Window Cleaning
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>

</body>
</html>
