---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../config';

const { businessName, phone, phoneE164, serviceKeyword, serviceKeywordPlural, city, region, faqs, services, cities, testimonials } = siteConfig;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map((f) => ({
    "@type": "Question",
    "name": f.question,
    "acceptedAnswer": { "@type": "Answer", "text": f.answer },
  })),
};
---

<BaseLayout
  title={`${businessName} | ${serviceKeyword.charAt(0).toUpperCase() + serviceKeyword.slice(1)} in ${city}`}
  description={`Need ${serviceKeyword} in ${city}? ${businessName} provides residential and commercial ${serviceKeywordPlural} in Florence, Covington, Fort Mitchell, and all across ${region}. Call ${phone} for a free estimate.`}
  schema={faqSchema}
>

<!-- HEADER -->
<header style="background:#fff;padding:0.75rem 3rem;border-bottom:1px solid #e5e7eb;">
  <div style="max-width:1100px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;">
    <a href={`tel:${phoneE164}`} style="color:#555;font-size:0.9rem;text-decoration:none;font-weight:500;">{phone}</a>
    <nav style="display:flex;gap:2rem;font-size:0.8rem;text-transform:uppercase;letter-spacing:0.5px;font-weight:600;">
      <a href="/" style="color:#333;text-decoration:none;">Home</a>
      <a href="/window-cleaning/" style="color:#333;text-decoration:none;">Services</a>
      <a href="/about/" style="color:#333;text-decoration:none;">About</a>
      <a href="/reviews/" style="color:#333;text-decoration:none;">Reviews</a>
    </nav>
  </div>
</header>

<!-- BUSINESS NAME -->
<div style="max-width:1100px;margin:0 auto;padding:2rem 3rem 0.5rem 3rem;">
  <h1 style="font-size:2.5rem;font-weight:800;color:#111;margin:0;line-height:1.15;font-family:Georgia,'Times New Roman',serif;">{businessName}</h1>
</div>

<!-- HERO + FORM side by side -->
<section style="max-width:1100px;margin:0 auto;padding:1rem 3rem 3rem 3rem;display:flex;gap:3rem;align-items:flex-start;">
  <!-- LEFT: Hero image -->
  <div style="flex:1;min-width:0;">
    <img src="/photos/hero.jpg" alt="Professional window cleaning technician at work" style="width:100%;height:300px;object-fit:cover;display:block;" loading="eager" />
    <div style="text-align:center;padding:1rem 0;">
      <a href={`tel:${phoneE164}`} style="display:inline-block;background:#1a6bb5;color:#fff;font-weight:700;font-size:0.95rem;padding:0.6rem 2rem;border-radius:4px;text-decoration:none;">CALL NOW</a>
    </div>
  </div>
  <!-- RIGHT: Form -->
  <div style="flex:0 0 340px;min-width:280px;">
    <div style="background:#1a6bb5;color:#fff;text-align:center;border-radius:6px 6px 0 0;padding:0.9rem 1rem;">
      <p style="font-size:1.25rem;font-weight:700;margin:0;">FREE INSTANT QUOTE</p>
      <p style="color:#cce4f7;font-size:0.75rem;margin:0.15rem 0 0 0;">ENTER YOUR INFO BELOW</p>
    </div>
    <form style="background:#fff;border:1px solid #ddd;border-top:none;border-radius:0 0 6px 6px;padding:1.25rem;" onsubmit="return false">
      <p style="font-size:0.75rem;color:#666;margin:0 0 0.75rem 0;">* Indicates required field</p>
      <!-- Name -->
      <div style="margin-bottom:0.75rem;">
        <label style="display:block;font-size:0.9rem;font-weight:600;color:#444;margin-bottom:0.25rem;">Name *</label>
        <div style="display:flex;gap:0.5rem;">
          <input type="text" name="firstName" required placeholder="First" style="flex:1;border:1px solid #ccc;border-radius:3px;padding:0.5rem;font-size:1rem;box-sizing:border-box;" />
          <input type="text" name="lastName" required placeholder="Last" style="flex:1;border:1px solid #ccc;border-radius:3px;padding:0.5rem;font-size:1rem;box-sizing:border-box;" />
        </div>
      </div>
      <!-- Phone -->
      <div style="margin-bottom:0.75rem;">
        <label style="display:block;font-size:0.9rem;font-weight:600;color:#444;margin-bottom:0.25rem;">Phone Number *</label>
        <input type="tel" name="phone" required style="width:100%;border:1px solid #ccc;border-radius:3px;padding:0.5rem;font-size:1rem;box-sizing:border-box;" />
      </div>
      <!-- Email -->
      <div style="margin-bottom:0.75rem;">
        <label style="display:block;font-size:0.9rem;font-weight:600;color:#444;margin-bottom:0.25rem;">Email *</label>
        <input type="email" name="email" required style="width:100%;border:1px solid #ccc;border-radius:3px;padding:0.5rem;font-size:1rem;box-sizing:border-box;" />
      </div>
      <!-- Comment -->
      <div style="margin-bottom:1rem;">
        <label style="display:block;font-size:0.9rem;font-weight:600;color:#444;margin-bottom:0.25rem;">Comment *</label>
        <textarea name="comment" required rows="3" style="width:100%;border:1px solid #ccc;border-radius:3px;padding:0.5rem;font-size:1rem;box-sizing:border-box;resize:vertical;font-family:inherit;"></textarea>
      </div>
      <button type="submit" style="width:100%;background:#1a6bb5;color:#fff;font-weight:700;font-size:1rem;padding:0.7rem;border:none;border-radius:4px;cursor:pointer;">Submit</button>
    </form>
  </div>
</section>

<!-- SERVICES -->
<section style="max-width:1100px;margin:0 auto;padding:0 3rem 4rem 3rem;">
  <h2 style="color:#1a6bb5;font-size:1.75rem;font-weight:700;margin:0 0 0.4rem 0;text-align:center;">Our Services</h2>
  <p style="color:#666;text-align:center;margin:0 0 2rem 0;font-size:0.95rem;">Professional window cleaning for homes and businesses in {city}</p>
  <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:2rem;">
    {services.map((service) => (
      <div style="border:1px solid #e5e7eb;border-radius:6px;overflow:hidden;">
        <img src={service.photo} alt={`${service.title} — ${businessName}`} style="width:100%;height:160px;object-fit:cover;" loading="lazy" />
        <div style="padding:1rem;">
          <h3 style="color:#1a6bb5;font-size:1.15rem;font-weight:700;margin:0 0 0.4rem 0;">{service.title}</h3>
          <p style="font-size:1.05rem;line-height:1.7;color:#555;margin:0;">{service.description}</p>
        </div>
      </div>
    ))}
  </div>
</section>

<!-- CONTENT -->
<section style="max-width:1100px;margin:0 auto;padding:0 3rem 4rem 3rem;">
  <h2 style="color:#1a6bb5;font-size:1.75rem;font-weight:700;margin:0 0 1rem 0;">{serviceKeyword.charAt(0).toUpperCase() + serviceKeyword.slice(1)} in {city}</h2>
  <p style="font-size:1.15rem;line-height:1.8;color:#444;margin-bottom:1rem;">If you need your windows cleaned in {city}, we are the team to call. We provide {serviceKeywordPlural} in Florence, Covington, Fort Mitchell, Erlanger, Newport, Independence, Edgewood, Fort Thomas, and all across {region}.</p>
  <p style="font-size:1.15rem;line-height:1.8;color:#444;margin-bottom:1rem;">{businessName} has been providing {serviceKeywordPlural} across {city} for years. We clean windows on homes, offices, storefronts, and commercial buildings. Whether you need the inside of your windows cleaned, the outside cleaned, or both — we can handle it.</p>
  <p style="font-size:1.15rem;line-height:1.8;color:#444;margin:0;">We use professional-grade equipment and eco-friendly cleaning solutions. Our purified water system leaves zero residue on your glass, so your windows stay cleaner longer.</p>
</section>

<!-- TESTIMONIALS -->
<section style="max-width:1100px;margin:0 auto;padding:0 3rem 4rem 3rem;">
  <h2 style="color:#1a6bb5;font-size:1.75rem;font-weight:700;margin:0 0 0.4rem 0;text-align:center;">What Our Customers Say</h2>
  <p style="color:#666;text-align:center;margin:0 0 2rem 0;font-size:0.95rem;">Reviews from homeowners and businesses across {city}</p>
  <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:1.5rem;">
    {testimonials.map((t) => (
      <div style="border-left:4px solid #1a6bb5;background:#f8f9fa;padding:1rem 1.25rem;border-radius:0 6px 6px 0;">
        <p style="font-style:italic;color:#444;margin:0 0 0.5rem 0;line-height:1.7;font-size:0.9rem;">"{t.quote}"</p>
        <p style="font-weight:600;color:#1a6bb5;font-size:0.8rem;margin:0;">— {t.name}, {t.city}</p>
      </div>
    ))}
  </div>
</section>

<!-- SERVICE AREAS -->
<section style="max-width:1100px;margin:0 auto;padding:0 3rem 4rem 3rem;">
  <h2 style="color:#1a6bb5;font-size:1.75rem;font-weight:700;margin:0 0 0.4rem 0;text-align:center;">Service Areas</h2>
  <p style="color:#666;text-align:center;margin:0 0 1.5rem 0;font-size:0.95rem;">We serve all of {city}. Don't see your city? Call us at {phone}.</p>
  <ul style="columns:3;list-style:disc;padding-left:1.25rem;line-height:2;color:#444;font-size:0.9rem;">
    {cities.map((c) => (
      <li><a href={`/window-cleaning/${c.slug}/`} style="color:#1a6bb5;text-decoration:none;">{c.name}</a></li>
    ))}
  </ul>
</section>

<!-- FAQ -->
<section style="max-width:1100px;margin:0 auto;padding:0 3rem 4rem 3rem;">
  <h2 style="color:#1a6bb5;font-size:1.75rem;font-weight:700;margin:0 0 0.4rem 0;text-align:center;">Frequently Asked Questions</h2>
  <p style="color:#666;text-align:center;margin:0 0 2rem 0;font-size:0.95rem;">Common questions about our window cleaning services</p>
  {faqs.map((faq, i) => (
    <div style={`padding:1rem 0;${i < faqs.length - 1 ? 'border-bottom:1px solid #e5e7eb;' : ''}`}>
      <p style="font-weight:700;color:#1a6bb5;margin:0 0 0.4rem 0;font-size:0.95rem;">{faq.question}</p>
      <p style="color:#555;font-size:1.05rem;line-height:1.75;margin:0;">{faq.answer}</p>
    </div>
  ))}
</section>

<!-- FINAL CTA -->
<section style="background:#1a6bb5;color:#fff;padding:3rem 3rem;text-align:center;">
  <h2 style="color:#fff;font-size:1.75rem;font-weight:700;margin:0 0 0.5rem 0;">Ready to Get Your Windows Cleaned?</h2>
  <p style="color:#cce4f7;font-size:0.95rem;margin:0 0 1.5rem 0;">Call now for a free estimate on window cleaning in {city}.</p>
  <a href={`tel:${phoneE164}`} style="display:inline-block;background:#fff;color:#1a6bb5;font-weight:700;font-size:1rem;padding:0.85rem 2.5rem;border-radius:6px;text-decoration:none;">Call {phone}</a>
</section>

</BaseLayout>
