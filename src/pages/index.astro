---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../config';

const { businessName, phone, phoneE164, serviceKeyword, serviceKeywordPlural, city, region, faqs, services, cities, testimonials } = siteConfig;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map((f) => ({
    "@type": "Question",
    "name": f.question,
    "acceptedAnswer": { "@type": "Answer", "text": f.answer },
  })),
};
---

<BaseLayout
  title={`${businessName} | ${serviceKeyword.charAt(0).toUpperCase() + serviceKeyword.slice(1)} in ${city}`}
  description={`Need ${serviceKeyword} in ${city}? ${businessName} provides residential and commercial ${serviceKeywordPlural} in Florence, Covington, Fort Mitchell, and all across ${region}. Call ${phone} for a free estimate.`}
  schema={faqSchema}
>

<style>
  .hero-form-row {
    display: flex;
    gap: 3rem;
    align-items: flex-start;
  }
  .hero-col {
    flex: 1;
    min-width: 0;
  }
  .form-col {
    flex: 0 0 400px;
    min-width: 0;
  }
  @media (max-width: 768px) {
    .hero-form-row {
      flex-direction: column;
      gap: 1.5rem;
    }
    .form-col {
      flex: none;
      width: 100%;
    }
    .page-pad {
      padding-left: 1.25rem !important;
      padding-right: 1.25rem !important;
    }
    .services-grid {
      grid-template-columns: 1fr !important;
    }
    .testimonials-grid {
      grid-template-columns: 1fr !important;
    }
    .areas-grid {
      columns: 2 !important;
    }
    .name-row {
      flex-direction: column !important;
      gap: 0.75rem !important;
    }
    .form-card {
      padding: 1.25rem !important;
    }
    .form-card input,
    .form-card textarea {
      font-size: 16px !important;
    }
  }
</style>

<!-- HEADER -->
<header style="background:#fff;padding:1rem 1.25rem;border-bottom:1px solid #e5e7eb;position:sticky;top:0;z-index:100;box-shadow:0 1px 8px rgba(0,0,0,0.08);">
  <div class="page-pad" style="max-width:1100px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;padding-left:2rem;padding-right:2rem;">
    <a href={`tel:${phoneE164}`} style="display:inline-block;background:#1a6bb5;color:#fff;font-size:0.95rem;font-weight:600;text-decoration:none;padding:0.5rem 1.25rem;border-radius:50px;transition:background 0.2s,box-shadow 0.2s;">📞 {phone}</a>
    <nav style="display:flex;gap:1.5rem;font-size:0.85rem;text-transform:uppercase;letter-spacing:0.5px;font-weight:600;">
      <a href="/" style="color:#333;text-decoration:none;transition:color 0.2s;">Home</a>
      <a href="/window-cleaning/" style="color:#333;text-decoration:none;transition:color 0.2s;">Services</a>
      <a href="/about/" style="color:#333;text-decoration:none;transition:color 0.2s;">About</a>
      <a href="/reviews/" style="color:#333;text-decoration:none;transition:color 0.2s;">Reviews</a>
    </nav>
  </div>
</header>

<!-- BUSINESS NAME -->
<div class="page-pad" style="max-width:1100px;margin:0 auto;padding:2rem 2rem 0.5rem 2rem;">
  <h1 style="font-size:clamp(1.75rem, 4vw, 2.5rem);font-weight:800;color:#111;margin:0;line-height:1.15;font-family:Georgia,'Times New Roman',serif;">{businessName}</h1>
</div>

<!-- HERO + FORM -->
<section class="page-pad" style="max-width:1100px;margin:0 auto;padding:1rem 2rem 3rem 2rem;">
  <div class="hero-form-row">
    <!-- LEFT: Hero -->
    <div class="hero-col">
      <img src="/photos/hero.jpg" alt="Professional window cleaning technician at work" style="width:100%;height:auto;display:block;max-height:350px;object-fit:cover;border-radius:12px;box-shadow:0 4px 20px rgba(0,0,0,0.1);" loading="eager" />
      <div style="text-align:center;padding:1.25rem 0;">
        <a href={`tel:${phoneE164}`} style="display:inline-block;background:#1a6bb5;color:#fff;font-weight:700;font-size:1.2rem;padding:0.85rem 3rem;border-radius:8px;text-decoration:none;box-shadow:0 4px 16px rgba(26,107,181,0.35);transition:box-shadow 0.2s,transform 0.2s;">CALL NOW</a>
      </div>
    </div>
    <!-- RIGHT: Form -->
    <div class="form-col">
      <div style="background:linear-gradient(135deg,#1a6bb5,#2d8fd5);color:#fff;text-align:center;border-radius:10px 10px 0 0;padding:1rem;">
        <p style="font-size:1.35rem;font-weight:700;margin:0;">FREE INSTANT QUOTE</p>
        <p style="color:#cce4f7;font-size:0.85rem;margin:0.2rem 0 0 0;">ENTER YOUR INFO BELOW</p>
      </div>
      <form style="background:#fff;border:1px solid #ddd;border-top:none;border-radius:0 0 10px 10px;padding:1.5rem;box-shadow:0 8px 30px rgba(0,0,0,0.08);" onsubmit="return false">
        <p style="font-size:0.8rem;color:#666;margin:0 0 1rem 0;">* Indicates required field</p>
        <!-- Name -->
        <div style="margin-bottom:1rem;">
          <label style="display:block;font-size:0.95rem;font-weight:600;color:#444;margin-bottom:0.3rem;">Name *</label>
          <div class="name-row" style="display:flex;gap:0.75rem;">
            <input type="text" name="firstName" required placeholder="First" style="flex:1;border:1px solid #ccc;border-radius:8px;padding:0.6rem 0.75rem;font-size:1rem;box-sizing:border-box;transition:border-color 0.2s,box-shadow 0.2s;" />
            <input type="text" name="lastName" required placeholder="Last" style="flex:1;border:1px solid #ccc;border-radius:8px;padding:0.6rem 0.75rem;font-size:1rem;box-sizing:border-box;transition:border-color 0.2s,box-shadow 0.2s;" />
          </div>
        </div>
        <!-- Phone -->
        <div style="margin-bottom:1rem;">
          <label style="display:block;font-size:0.95rem;font-weight:600;color:#444;margin-bottom:0.3rem;">Phone Number *</label>
          <input type="tel" name="phone" required style="width:100%;border:1px solid #ccc;border-radius:8px;padding:0.6rem 0.75rem;font-size:1rem;box-sizing:border-box;transition:border-color 0.2s,box-shadow 0.2s;" />
        </div>
        <!-- Email -->
        <div style="margin-bottom:1rem;">
          <label style="display:block;font-size:0.95rem;font-weight:600;color:#444;margin-bottom:0.3rem;">Email *</label>
          <input type="email" name="email" required style="width:100%;border:1px solid #ccc;border-radius:8px;padding:0.6rem 0.75rem;font-size:1rem;box-sizing:border-box;transition:border-color 0.2s,box-shadow 0.2s;" />
        </div>
        <!-- Comment -->
        <div style="margin-bottom:1.25rem;">
          <label style="display:block;font-size:0.95rem;font-weight:600;color:#444;margin-bottom:0.3rem;">Comment *</label>
          <textarea name="comment" required rows="4" style="width:100%;border:1px solid #ccc;border-radius:8px;padding:0.6rem 0.75rem;font-size:1rem;box-sizing:border-box;resize:vertical;font-family:inherit;transition:border-color 0.2s,box-shadow 0.2s;"></textarea>
        </div>
        <button type="submit" style="width:100%;background:linear-gradient(135deg,#1a6bb5,#2d8fd5);color:#fff;font-weight:700;font-size:1.05rem;padding:0.75rem;border:none;border-radius:8px;cursor:pointer;box-shadow:0 4px 12px rgba(26,107,181,0.3);transition:box-shadow 0.2s,transform 0.2s;">Submit</button>
      </form>
    </div>
  </div>
</section>

<!-- SERVICES -->
<section class="page-pad" style="max-width:1100px;margin:0 auto;padding:0 2rem 3rem 2rem;">
  <h2 style="color:#1a6bb5;font-size:1.75rem;font-weight:700;margin:0 0 0.4rem 0;text-align:center;">Our Services</h2>
  <p style="color:#666;text-align:center;margin:0 0 2rem 0;font-size:1.1rem;">Professional window cleaning for homes and businesses in {city}</p>
  <div class="services-grid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;">
    {services.map((service) => (
      <div style="border:1px solid #e5e7eb;border-radius:12px;overflow:hidden;box-shadow:0 2px 12px rgba(0,0,0,0.06);transition:box-shadow 0.2s,transform 0.2s;">
        <img src={service.photo} alt={`${service.title} — ${businessName}`} style="width:100%;height:180px;object-fit:cover;" loading="lazy" />
        <div style="padding:1.25rem;">
          <h3 style="color:#1a6bb5;font-size:1.15rem;font-weight:700;margin:0 0 0.4rem 0;">{service.title}</h3>
          <p style="font-size:1.05rem;line-height:1.7;color:#555;margin:0;">{service.description}</p>
        </div>
      </div>
    ))}
  </div>
</section>

<!-- CONTENT -->
<section class="page-pad" style="max-width:1100px;margin:0 auto;padding:0 2rem 3rem 2rem;">
  <h2 style="color:#1a6bb5;font-size:1.75rem;font-weight:700;margin:0 0 1rem 0;">{serviceKeyword.charAt(0).toUpperCase() + serviceKeyword.slice(1)} in {city}</h2>
  <p style="font-size:1.15rem;line-height:1.8;color:#444;margin-bottom:1rem;">If you need your windows cleaned in {city}, we are the team to call. We provide {serviceKeywordPlural} in Florence, Covington, Fort Mitchell, Erlanger, Newport, Independence, Edgewood, Fort Thomas, and all across {region}.</p>
  <p style="font-size:1.15rem;line-height:1.8;color:#444;margin-bottom:1rem;">{businessName} has been providing {serviceKeywordPlural} across {city} for years. We clean windows on homes, offices, storefronts, and commercial buildings. Whether you need the inside of your windows cleaned, the outside cleaned, or both — we can handle it.</p>
  <p style="font-size:1.15rem;line-height:1.8;color:#444;margin:0;">We use professional-grade equipment and eco-friendly cleaning solutions. Our purified water system leaves zero residue on your glass, so your windows stay cleaner longer.</p>
</section>

<!-- TESTIMONIALS -->
<section class="page-pad" style="max-width:1100px;margin:0 auto;padding:0 2rem 3rem 2rem;">
  <h2 style="color:#1a6bb5;font-size:1.75rem;font-weight:700;margin:0 0 0.4rem 0;text-align:center;">What Our Customers Say</h2>
  <p style="color:#666;text-align:center;margin:0 0 2rem 0;font-size:1.1rem;">Reviews from homeowners and businesses across {city}</p>
  <div class="testimonials-grid" style="display:grid;grid-template-columns:repeat(2,1fr);gap:1.5rem;">
    {testimonials.map((t) => (
      <div style="border-left:4px solid #1a6bb5;background:#f8f9fa;padding:1.25rem;border-radius:10px;box-shadow:0 2px 8px rgba(0,0,0,0.04);">
        <p style="font-style:italic;color:#444;margin:0 0 0.5rem 0;line-height:1.7;font-size:1.05rem;">&#9733;&#9733;&#9733;&#9733;&#9733; "{t.quote}"</p>
        <p style="font-weight:600;color:#1a6bb5;font-size:0.9rem;margin:0;">— {t.name}, {t.city}</p>
      </div>
    ))}
  </div>
</section>

<!-- SERVICE AREAS -->
<section class="page-pad" style="max-width:1100px;margin:0 auto;padding:0 2rem 3rem 2rem;">
  <h2 style="color:#1a6bb5;font-size:1.75rem;font-weight:700;margin:0 0 0.4rem 0;text-align:center;">Service Areas</h2>
  <p style="color:#666;text-align:center;margin:0 0 1.5rem 0;font-size:1.1rem;">We serve all of {city}. Don't see your city? Call us at {phone}.</p>
  <ul class="areas-grid" style="columns:3;list-style:disc;padding-left:1.25rem;line-height:2.2;color:#444;font-size:1rem;">
    {cities.map((c) => (
      <li><a href={`/window-cleaning/${c.slug}/`} style="color:#1a6bb5;text-decoration:none;transition:color 0.2s;">{c.name}</a></li>
    ))}
  </ul>
</section>

<!-- FAQ -->
<section class="page-pad" style="max-width:1100px;margin:0 auto;padding:0 2rem 3rem 2rem;">
  <h2 style="color:#1a6bb5;font-size:1.75rem;font-weight:700;margin:0 0 0.4rem 0;text-align:center;">Frequently Asked Questions</h2>
  <p style="color:#666;text-align:center;margin:0 0 2rem 0;font-size:1.1rem;">Common questions about our window cleaning services</p>
  {faqs.map((faq, i) => (
    <div style={`padding:1.25rem 0;${i < faqs.length - 1 ? 'border-bottom:1px solid #e5e7eb;' : ''}`}>
      <p style="font-weight:700;color:#1a6bb5;margin:0 0 0.5rem 0;font-size:1.15rem;">{faq.question}</p>
      <p style="color:#555;font-size:1.05rem;line-height:1.75;margin:0;">{faq.answer}</p>
    </div>
  ))}
</section>

<!-- FINAL CTA -->
<section style="background:linear-gradient(135deg,#1a6bb5 0%,#155a96 100%);color:#fff;padding:3rem 2rem;text-align:center;">
  <h2 style="color:#fff;font-size:1.75rem;font-weight:700;margin:0 0 0.5rem 0;">Ready to Get Your Windows Cleaned?</h2>
  <p style="color:#cce4f7;font-size:1.1rem;margin:0 0 1.5rem 0;">Call now for a free estimate on window cleaning in {city}.</p>
  <a href={`tel:${phoneE164}`} style="display:inline-block;background:#fff;color:#1a6bb5;font-weight:700;font-size:1.15rem;padding:1rem 2.5rem;border-radius:8px;text-decoration:none;box-shadow:0 4px 16px rgba(0,0,0,0.2);transition:transform 0.2s,box-shadow 0.2s;">Call {phone}</a>
</section>

</BaseLayout>
