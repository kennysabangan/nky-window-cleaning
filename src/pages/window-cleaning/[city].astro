---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PhoneCTA from '../../components/PhoneCTA.astro';
import { cities } from '../../data/cities';
import { services } from '../../data/services';

export function getStaticPaths() {
  return cities.map(city => ({
    params: { city: city.slug },
    props: { city }
  }));
}

const { city } = Astro.props;

const schema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "NKY Window Cleaning Pros",
  "description": `Professional window cleaning services in ${city.name}. Residential and commercial window cleaning by NKY Window Cleaning Pros.`,
  "url": `https://nkywindowcleaningpros.com/window-cleaning/${city.slug}/`,
  "telephone": "+18595550100",
  "areaServed": {
    "@type": "City",
    "name": city.name,
    "address": {
      "@type": "PostalAddress",
      "addressRegion": "KY",
      "addressCountry": "US"
    }
  },
  "serviceType": ["Window Cleaning", "Residential Window Cleaning", "Commercial Window Cleaning"]
};
---

<BaseLayout
  title={`Window Cleaning in ${city.name} | NKY Window Cleaning Pros`}
  description={`Need window cleaning in ${city.name}? NKY Window Cleaning Pros provides residential and commercial window cleaning in ${city.name} and all across Northern Kentucky. Call (859) 555-0100 for a free estimate.`}
  canonicalURL={`https://nkywindowcleaningpros.com/window-cleaning/${city.slug}/`}
  schema={schema}
>

<!-- Big headline banner -->
<table width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#1a6bb5; color:#fff; padding:25px 0;">
  <tr>
    <td align="center" style="padding:25px 15px;">
      <h1 style="color:#fff; font-size:28px; margin:0 0 10px 0;">Window Cleaning in {city.name}</h1>
      <p style="color:#cce4f7; font-size:16px; margin:0 0 15px 0;">Residential and commercial window cleaning in {city.name}, Kentucky. Streak-free results, every time.</p>
      <PhoneCTA />
    </td>
  </tr>
</table>

<!-- Photo -->
<div style="text-align:center; padding:10px;">
  <img src="/photos/window-cleaning-1.jpg" alt={`Window cleaning in ${city.name}`} style="width:100%; max-width:600px; height:auto;" />
</div>

<!-- City intro content -->
<div class="content-section">
  <h2 style="color:#1a6bb5; font-size:22px; margin-top:0;">Window Cleaning Services in {city.name}</h2>

  <p>{city.intro}</p>

  <p>If you're looking for reliable window cleaning in {city.name}, look no further. NKY Window Cleaning Pros has been cleaning windows in {city.name} and the surrounding Northern Kentucky communities for years. We clean windows on homes, offices, storefronts, and commercial buildings throughout {city.name}. Whether you need residential window cleaning or commercial window cleaning, we've got you covered.</p>

  <img src="/photos/window-cleaning-2.jpg" alt={`Residential window cleaning ${city.name}`} style="width:100%; max-width:500px; height:auto; display:block; margin:15px auto;" />

  <p>Our window cleaning service in {city.name} includes interior and exterior window cleaning, screen cleaning, track cleaning, and hard water stain removal. We use professional-grade equipment and eco-friendly cleaning solutions that are safe for your family and pets. The purified water system we use leaves zero residue, so your windows in {city.name} stay cleaner longer.</p>
</div>

<!-- Phone CTA -->
<table width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#f5f5f5; border-top:2px solid #1a6bb5; border-bottom:2px solid #1a6bb5;">
  <tr>
    <td align="center" style="padding:20px 15px;">
      <p style="font-size:16px; color:#333; margin:0 0 5px 0; font-weight:bold;">Need Window Cleaning in {city.name}?</p>
      <p style="font-size:13px; color:#666; margin:0 0 10px 0;">Call now for a free estimate.</p>
      <PhoneCTA />
    </td>
  </tr>
</table>

<!-- Services offered in this city -->
<div class="content-section">
  <h2 style="color:#1a6bb5; font-size:22px; margin-top:0;">Window Cleaning Services We Offer in {city.name}</h2>

  <p>We provide a full range of window cleaning services in {city.name} and throughout Northern Kentucky:</p>

  <ul style="line-height:2; padding-left:20px;">
    {services.map(service => (
      <li><strong>{service.title}</strong> — {service.description.split('.').slice(0, 2).join('.')}.</li>
    ))}
  </ul>
</div>

<!-- Photo -->
<div style="text-align:center; padding:10px;">
  <img src="/photos/window-cleaning-3.jpg" alt={`Window cleaning team ${city.name}`} style="width:100%; max-width:600px; height:auto;" />
</div>

<!-- Why choose us — simple -->
<div class="content-section">
  <h2 style="color:#1a6bb5; font-size:22px; margin-top:0;">Why {city.name} Residents Choose Us for Window Cleaning</h2>

  <ul style="line-height:2; padding-left:20px;">
    <li>Licensed and insured window cleaning company serving Northern Kentucky</li>
    <li>Background-checked technicians who treat your {city.name} home with respect</li>
    <li>Flexible scheduling — we work around your availability</li>
    <li>Eco-friendly, professional-grade window cleaning solutions</li>
    <li>100% satisfaction guarantee on every window cleaning job</li>
    <li>Locally owned and operated — we're your Northern Kentucky neighbors</li>
  </ul>
</div>

<!-- Nearby cities -->
<div class="content-section">
  <h2 style="color:#1a6bb5; font-size:22px; margin-top:0;">We Also Serve These Nearby Northern Kentucky Cities</h2>

  <p>In addition to window cleaning in {city.name}, we also provide window cleaning services in these nearby Northern Kentucky communities:</p>

  <ul style="line-height:2; padding-left:20px;">
    {cities.filter(c => c.slug !== city.slug).slice(0, 8).map(c => (
      <li><a href={`/window-cleaning/${c.slug}/`} style="color:#1a6bb5; text-decoration:none;">Window Cleaning in {c.name}</a></li>
    ))}
  </ul>
</div>

<!-- Final CTA -->
<table width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#1a6bb5;">
  <tr>
    <td align="center" style="padding:25px 15px;">
      <h2 style="color:#fff; font-size:22px; margin:0 0 10px 0;">Get Your Windows Cleaned in {city.name} Today</h2>
      <p style="color:#cce4f7; font-size:15px; margin:0 0 15px 0;">Call now for a free estimate on window cleaning in {city.name}, KY.</p>
      <PhoneCTA label="Call Now" />
    </td>
  </tr>
</table>

</BaseLayout>
